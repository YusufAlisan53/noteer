{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist-electron",
    "skipLibCheck": true
  },
  "include": ["electron", "src/types"],
  "exclude": ["node_modules"]
}
